{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "cd client && node node_modules/vite/bin/vite.js build",
  "outputDirectory": "client/dist",
  "installCommand": "cd client && npm install",
  "framework": null,
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
